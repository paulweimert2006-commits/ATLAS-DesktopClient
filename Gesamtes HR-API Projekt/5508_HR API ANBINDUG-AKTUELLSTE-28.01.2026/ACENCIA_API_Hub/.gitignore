# =============================================================================
# ACENCIA Hub - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Application Data - NICHT COMMITTEN (Sensible Daten)
# -----------------------------------------------------------------------------

# Benutzerdatenbank (enthält Passwort-Hashes)
acencia_hub/data/users.json

# Geheimnisse (GitHub PAT, etc.)
acencia_hub/data/secrets.json

# Arbeitgeber-Konfiguration (enthält API-Credentials)
acencia_hub/data/employers.json

# Forced Logout Timestamp
acencia_hub/data/force_logout.txt

# Trigger-Konfiguration (enthält SMTP-Passwort, API-Tokens)
acencia_hub/data/triggers.json

# Trigger-Ausführungsprotokoll (enthält Mitarbeiterdaten)
acencia_hub/data/trigger_log.json

# -----------------------------------------------------------------------------
# Generierte Daten
# -----------------------------------------------------------------------------

# Snapshots (benutzerspezifische Daten)
acencia_hub/_snapshots/

# API-Response-History
acencia_hub/_history/

# Generierte Exporte
acencia_hub/exports/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
server.log
logs/

# -----------------------------------------------------------------------------
# Temporäre Dateien
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
update_temp/

# -----------------------------------------------------------------------------
# Test Coverage
# -----------------------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Ausnahmen - Diese Dateien SOLLEN committed werden
# -----------------------------------------------------------------------------
# Beispiel-Konfigurationen könnten hier mit ! ausgenommen werden
# !acencia_hub/data/users.example.json
